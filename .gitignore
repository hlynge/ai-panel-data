# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# ─── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store

# ─── Data — raw downloads (can be large; regenerate with main.py) ─────────────
data/raw/
!data/raw/.gitkeep

# ─── Processed outputs (derived; regenerate with main.py) ────────────────────
data/processed/
!data/processed/.gitkeep

# ─── Jupyter checkpoints ──────────────────────────────────────────────────────
.ipynb_checkpoints/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Secrets / credentials ────────────────────────────────────────────────────
.env
*.secret
credentials.yaml
